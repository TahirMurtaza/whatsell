APP_NAME=whatsell
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=whatsell
POSTGRES_PASSWORD=whatsell_secret
POSTGRES_DB=whatsell_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=whatsell_conversations

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# WASenderAPI (WhatsApp)
# 1. Sign up at https://app.wasenderapi.com
# 2. Connect a WhatsApp session via QR code
# 3. Generate a Personal Access Token
# 4. Register your webhook URL and copy the webhook secret
WASENDER_API_KEY=your-wasender-api-key
WASENDER_WEBHOOK_SECRET=your-webhook-secret
WASENDER_BASE_URL=https://api.wasenderapi.com

# Langfuse (self-hosted on port 3001)
# Admin UI: http://localhost:3001  |  Login: admin@whatsell.local / <LANGFUSE_INIT_USER_PASSWORD>
LANGFUSE_SECRET_KEY=sk-lf-whatsell-dev
LANGFUSE_PUBLIC_KEY=pk-lf-whatsell-dev
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_UI_URL=http://localhost:3001
LANGFUSE_NEXTAUTH_SECRET=<32-char-random-string>
LANGFUSE_SALT=<32-char-random-string>
LANGFUSE_INIT_USER_PASSWORD=<your-admin-password>

# Webhook URL to register in the WASenderAPI dashboard:
#   https://your-domain.com/api/v1/webhooks/whatsapp
# For local testing, expose port 8000 via ngrok:
#   ngrok http 8000  ->  https://xxxx.ngrok.io/api/v1/webhooks/whatsapp
